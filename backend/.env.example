# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=8192
OPENAI_TEMPERATURE=0.2

# ── PDF limits ────────────────────────────────────
MAX_PDF_SIZE_MB=20
MAX_PDFS_PER_REQUEST=5
MAX_CHUNK_TOKENS=600
MAX_CONTEXT_CHUNKS=15

# ── CORS ──────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
